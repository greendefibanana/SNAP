{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "strict": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "resolveJsonModule": true,
        "declaration": false,
        "sourceMap": true,
        "types": [
            "node",
            "mocha",
            "chai"
        ]
    },
    "include": [
        "tests/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}